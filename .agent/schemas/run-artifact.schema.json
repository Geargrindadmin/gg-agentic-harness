{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://geargrind.local/schemas/run-artifact.schema.json",
  "title": "Agent Run Artifact",
  "type": "object",
  "required": [
    "schemaVersion",
    "runId",
    "createdAt",
    "updatedAt",
    "status",
    "runtimeProfile",
    "classification",
    "selectedSkills",
    "mcpCalls",
    "gates"
  ],
  "properties": {
    "schemaVersion": { "type": "integer", "const": 1 },
    "runId": { "type": "string", "minLength": 1 },
    "createdAt": { "type": "string", "format": "date-time" },
    "updatedAt": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["in_progress", "success", "failed"] },
    "runtimeProfile": { "type": "string", "enum": ["codex", "claude", "kimi"] },
    "activeRuntime": { "type": "string", "enum": ["codex", "claude", "kimi"] },
    "classification": {
      "type": "string",
      "enum": ["SIMPLE", "TASK", "TASK_LITE", "DECISION", "CRITICAL"]
    },
    "taskSummary": { "type": "string" },
    "contextSource": { "type": "string", "enum": ["", "standard", "codegraphcontext", "hybrid"] },
    "integrationFlags": {
      "type": "object",
      "properties": {
        "codeGraphContextMode": { "type": "string", "enum": ["", "off", "prefer", "hybrid", "required"] },
        "promptImproverMode": { "type": "string", "enum": ["", "off", "auto", "force"] },
        "hydraMode": { "type": "string", "enum": ["", "off", "shadow", "active"] }
      },
      "additionalProperties": false
    },
    "promptVersion": { "type": "string", "pattern": "^$|^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "workflowVersion": { "type": "string", "pattern": "^$|^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "blueprintVersion": { "type": "string", "pattern": "^$|^v[0-9]+\\.[0-9]+\\.[0-9]+(?:-[0-9A-Za-z.-]+)?$" },
    "toolBundle": { "type": "string" },
    "riskTier": { "type": "string", "enum": ["", "low", "medium", "high"] },
    "selectedSkills": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 }
    },
    "mcpCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["server", "tool", "status", "timestamp"],
        "properties": {
          "server": { "type": "string" },
          "tool": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
          "timestamp": { "type": "string", "format": "date-time" },
          "detail": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "gates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command", "exitCode", "attempt", "timestamp"],
        "properties": {
          "name": { "type": "string" },
          "status": { "type": "string", "enum": ["pass", "fail", "skipped"] },
          "command": { "type": "string" },
          "exitCode": { "type": "integer" },
          "attempt": { "type": "integer", "minimum": 1 },
          "detail": { "type": "string" },
          "signature": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "events": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["eventType", "summary", "status", "timestamp"],
        "properties": {
          "eventType": { "type": "string" },
          "summary": { "type": "string" },
          "status": { "type": "string", "enum": ["info", "pass", "fail", "blocked"] },
          "detail": { "type": "string" },
          "target": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "retries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["gate", "attempts"],
        "properties": {
          "gate": { "type": "string" },
          "attempts": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": false
      }
    },
    "failureSignatures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["signature", "gate", "count", "firstSeenAt", "lastSeenAt"],
        "properties": {
          "signature": { "type": "string", "minLength": 1 },
          "gate": { "type": "string", "minLength": 1 },
          "count": { "type": "integer", "minimum": 1 },
          "firstSeenAt": { "type": "string", "format": "date-time" },
          "lastSeenAt": { "type": "string", "format": "date-time" },
          "lastCommand": { "type": "string" },
          "lastDetail": { "type": "string" },
          "lastExitCode": { "type": "integer" },
          "failureCode": { "type": "string" },
          "failurePath": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "feedbackLoops": {
      "type": "object",
      "properties": {
        "internal": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/feedbackEntry"
          }
        },
        "external": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/feedbackEntry"
          }
        }
      },
      "additionalProperties": false
    },
    "personaRouting": {
      "type": ["object", "null"],
      "required": [
        "routingConfidence",
        "dispatchPlan",
        "boardRequired",
        "highRiskTerms",
        "createPersonaSuggested",
        "promoteCompoundSuggested",
        "primaryPersonaId",
        "collaboratorPersonaIds",
        "matchedPersonaIds",
        "compoundPersona",
        "recordedAt"
      ],
      "properties": {
        "routingConfidence": {
          "type": "string",
          "enum": ["none", "low", "medium", "high"]
        },
        "dispatchPlan": { "type": "string" },
        "boardRequired": { "type": "boolean" },
        "highRiskTerms": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "createPersonaSuggested": { "type": "boolean" },
        "promoteCompoundSuggested": { "type": "boolean" },
        "primaryPersonaId": { "type": "string" },
        "collaboratorPersonaIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "matchedPersonaIds": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "compoundPersona": {
          "type": ["object", "null"],
          "required": [
            "id",
            "source",
            "riskTier",
            "dispatchPlan",
            "primaryPersonaId",
            "collaboratorPersonaIds",
            "memberPersonaIds",
            "memoryQuery",
            "summary",
            "reasons",
            "score",
            "promoteSuggested",
            "signature"
          ],
          "properties": {
            "id": { "type": "string" },
            "source": { "type": "string", "enum": ["registry", "runtime", ""] },
            "riskTier": { "type": "string", "enum": ["low", "medium", "high", ""] },
            "dispatchPlan": { "type": "string" },
            "primaryPersonaId": { "type": "string" },
            "collaboratorPersonaIds": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "memberPersonaIds": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "memoryQuery": { "type": "string" },
            "summary": { "type": "string" },
            "reasons": {
              "type": "array",
              "items": { "type": "string", "minLength": 1 }
            },
            "score": { "type": ["integer", "number", "null"] },
            "promoteSuggested": { "type": "boolean" },
            "signature": { "type": "string" }
          },
          "additionalProperties": false
        },
        "recordedAt": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    },
    "delegationDecisions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "decisionId",
          "runId",
          "fromAgentId",
          "requestedRuntime",
          "requestedRole",
          "personaId",
          "taskSummary",
          "classification",
          "boardRequired",
          "highRiskTerms",
          "status",
          "rationale",
          "timestamp",
          "spawnedAgentId"
        ],
        "properties": {
          "decisionId": { "type": "string", "minLength": 1 },
          "runId": { "type": "string", "minLength": 1 },
          "fromAgentId": { "type": "string", "minLength": 1 },
          "requestedRuntime": { "type": "string", "enum": ["codex", "claude", "kimi"] },
          "requestedRole": { "type": "string", "minLength": 1 },
          "personaId": { "type": "string", "minLength": 1 },
          "taskSummary": { "type": "string" },
          "classification": {
            "type": "string",
            "enum": ["SIMPLE", "TASK", "TASK_LITE", "DECISION", "CRITICAL"]
          },
          "boardRequired": { "type": "boolean" },
          "highRiskTerms": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "status": { "type": "string", "enum": ["approved", "rejected"] },
          "rationale": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" },
          "spawnedAgentId": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "delegationFailures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["decisionId", "fromAgentId", "requestedRuntime", "personaId", "reason", "timestamp"],
        "properties": {
          "decisionId": { "type": "string", "minLength": 1 },
          "fromAgentId": { "type": "string", "minLength": 1 },
          "requestedRuntime": { "type": "string", "enum": ["codex", "claude", "kimi"] },
          "personaId": { "type": "string", "minLength": 1 },
          "reason": { "type": "string" },
          "timestamp": { "type": "string", "format": "date-time" }
        },
        "additionalProperties": false
      }
    },
    "workerGraph": {
      "type": "object",
      "required": ["workers", "edges"],
      "properties": {
        "workers": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["agentId", "runtime", "role", "personaId", "parentAgentId", "status"],
            "properties": {
              "agentId": { "type": "string", "minLength": 1 },
              "runtime": { "type": "string", "enum": ["codex", "claude", "kimi"] },
              "role": { "type": "string", "minLength": 1 },
              "personaId": { "type": "string", "minLength": 1 },
              "parentAgentId": { "type": ["string", "null"] },
              "status": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["fromAgentId", "toAgentId", "relation"],
            "properties": {
              "fromAgentId": { "type": "string", "minLength": 1 },
              "toAgentId": { "type": "string", "minLength": 1 },
              "relation": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "messageBusHealth": {
      "type": "object",
      "required": ["status", "transport", "pendingMessages", "lastCursor"],
      "properties": {
        "status": { "type": "string", "enum": ["healthy", "degraded"] },
        "transport": { "type": "string", "minLength": 1 },
        "pendingMessages": { "type": "integer", "minimum": 0 },
        "lastCursor": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "runtimeScorecards": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "runtime",
          "adapterMode",
          "status",
          "mcpServers",
          "optionalMcpServers",
          "disabledMcpServers"
        ],
        "properties": {
          "runtime": { "type": "string", "enum": ["codex", "claude", "kimi"] },
          "adapterMode": { "type": "string", "enum": ["host-activated", "contract-only", "provider-api"] },
          "status": { "type": "string", "enum": ["available"] },
          "mcpServers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "optionalMcpServers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          },
          "disabledMcpServers": {
            "type": "array",
            "items": { "type": "string", "minLength": 1 }
          }
        },
        "additionalProperties": false
      }
    },
    "rollback": {
      "type": ["object", "null"],
      "properties": {
        "trigger": { "type": "string" },
        "executed": { "type": "boolean" },
        "notes": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "$defs": {
    "feedbackEntry": {
      "type": "object",
      "required": ["kind", "status", "summary", "timestamp"],
      "properties": {
        "kind": { "type": "string", "minLength": 1 },
        "status": {
          "type": "string",
          "enum": ["info", "triggered", "accepted", "skipped", "pass", "fail", "blocked"]
        },
        "summary": { "type": "string", "minLength": 1 },
        "detail": { "type": "string" },
        "target": { "type": "string" },
        "trigger": { "type": "string" },
        "proposalPath": { "type": "string" },
        "signature": { "type": "string" },
        "sourceRuns": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "gate": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
